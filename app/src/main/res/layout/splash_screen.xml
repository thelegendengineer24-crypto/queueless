<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mesh_gradient">

    <!-- Top-right purple glow -->
    <View
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-160dp"
        android:layout_marginEnd="-120dp"
        android:background="@drawable/glow_circle_purple"
        android:alpha="0.6" />

    <!-- Bottom-left blue glow -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="-120dp"
        android:layout_marginStart="-70dp"
        android:background="@drawable/glow_circle_blue"
        android:alpha="0.5" />

    <!-- Center: Logo + tagline -->
    <LinearLayout
        android:id="@+id/centerContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <!-- Glow ring behind logo -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:layout_marginBottom="28dp">

            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/glow_circle_blue"
                android:alpha="0.35" />

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_queueless"
                android:scaleType="fitCenter"
                android:contentDescription="Queueless Logo" />

        </FrameLayout>

        <!-- App name -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QueueLess"
            android:textColor="#E2E8F0"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:gravity="center" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Skip the wait. Not the service."
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:letterSpacing="0.02" />

    </LinearLayout>

    <!-- Bottom: progress bar + version -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="52dp"
        android:paddingHorizontal="60dp">

        <ProgressBar
            android:id="@+id/splashProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:indeterminate="true"
            android:indeterminateTint="#C74680FF"
            android:progressBackgroundTint="#1A4680FF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="v1.0.0"
            android:textColor="#4A5568"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

</RelativeLayout>