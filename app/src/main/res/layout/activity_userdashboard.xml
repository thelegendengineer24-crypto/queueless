<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1E">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_mesh_gradient" />

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="-80dp"
        android:layout_marginStart="-80dp"
        android:background="@drawable/glow_circle_blue"
        android:alpha="0.35" />

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/glow_circle_purple"
        android:alpha="0.4" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ══ HEADER ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="46dp"
                android:paddingBottom="8dp">

                <!-- Top Row (Modified to include QR Button) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="QueueLess"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium" />

                    <!-- ✅ QR Scan Button (Moved Here) -->
                    <ImageView
                        android:id="@+id/btnScanQr"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_scanner"
                        android:background="@drawable/bg_icon_button"
                        android:padding="10dp"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="Scan QR"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless" />

                    <ImageView
                        android:id="@+id/btnNotification"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_bell"
                        android:background="@drawable/bg_icon_button"
                        android:padding="10dp"
                        android:contentDescription="Notifications" />

                    <!-- Avatar -->
                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_profile"
                        android:background="@drawable/bg_avatar_circle"
                        android:scaleType="centerCrop"
                        android:layout_marginStart="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Profile" />

                </LinearLayout>

                <!-- Greeting -->
                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good Morning,"
                    android:textSize="14sp"
                    android:textColor="#8A9BC8"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="User 👋"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvActiveBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Live"
                        android:textSize="11sp"
                        android:textColor="#00E676"
                        android:background="@drawable/bg_live_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══ HERO TOKEN CARD ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardActiveToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_glass_card_blue"
                    android:padding="20dp">

                    <!-- Token Label + Status -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Your Token"
                            android:textSize="13sp"
                            android:textColor="#A8C4FF"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvTokenStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inactive"
                            android:textSize="11sp"
                            android:textColor="#FFD54F"
                            android:background="@drawable/bg_status_badge_yellow"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp" />

                    </LinearLayout>

                    <!-- Token Number + Now Serving -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tvTokenNumber"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="---"
                            android:textSize="56sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="-0.02" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Now Serving"
                                android:textSize="10sp"
                                android:textColor="#7A9AD4"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:id="@+id/tvNowServing"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#00E676" />

                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvBusinessName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No active token"
                        android:textSize="13sp"
                        android:textColor="#A8C4FF"
                        android:layout_marginBottom="12dp" />

                    <!-- Queue Progress -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:id="@+id/tvQueuePosition"
                            android:text="No active queue"
                            android:textSize="11sp"
                            android:textColor="#7A9AD4" />

                        <TextView
                            android:id="@+id/tvWaitTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- min"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressQueue"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:progressDrawable="@drawable/progress_queue_gradient"
                        android:background="@drawable/bg_progress_track"
                        android:layout_marginBottom="14dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewStatus"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:text="Refresh Status"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#1A3A7A"
                        style="@style/Widget.Material3.Button" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ TAKE NEW TOKEN SECTION ══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Take a New Token"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card_dark"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:padding="16dp">

                <!-- Search Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Search business..."
                    app:startIconDrawable="@drawable/ic_search"
                    app:startIconTint="#6B8CC7"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxBackgroundColor="#1A2444"
                    app:boxStrokeColor="#2952A3"
                    app:hintTextColor="#6B8CC7"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearchBusiness"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:textColor="#FFFFFF"
                        android:imeOptions="actionSearch"
                        android:inputType="text" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Business Dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select Business"
                    app:startIconDrawable="@drawable/ic_store"
                    app:startIconTint="#6B8CC7"
                    app:endIconMode="dropdown_menu"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxBackgroundColor="#1A2444"
                    app:boxStrokeColor="#2952A3"
                    app:hintTextColor="#6B8CC7"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_marginBottom="12dp">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerBusiness"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:textColor="#FFFFFF"
                        android:inputType="none" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Selected Business Chip -->
                <LinearLayout
                    android:id="@+id/layoutSelectedBusiness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_selected_chip"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_store"
                        android:background="@drawable/bg_icon_teal"
                        android:padding="5dp"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="Business Icon" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selected"
                            android:textSize="10sp"
                            android:textColor="#5C7DB0" />

                        <TextView
                            android:id="@+id/tvSelectedBusiness"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="---"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="Selected"
                        android:tint="#00E676" />

                </LinearLayout>

                <!-- Generate Token Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGenerateToken"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Generate Token"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.02"
                    app:cornerRadius="14dp"
                    app:backgroundTint="#1565C0"
                    app:icon="@drawable/ic_token"
                    app:iconGravity="textStart"
                    app:iconTint="#FFFFFF"
                    style="@style/Widget.Material3.Button" />

            </LinearLayout>

            <!-- ══ QUICK ACTIONS ══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:weightSum="3">

                <LinearLayout
                    android:id="@+id/cardStatus"
                    android:layout_width="0dp"
                    android:layout_height="84dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_quick_action_blue"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_queue_status"
                        android:tint="#FFFFFF"
                        android:layout_marginBottom="6dp"
                        android:contentDescription="Token Status" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Token\nStatus"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardHistory"
                    android:layout_width="0dp"
                    android:layout_height="84dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_quick_action_teal"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_history"
                        android:tint="#FFFFFF"
                        android:layout_marginBottom="6dp"
                        android:contentDescription="History" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My\nHistory"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardLogout"
                    android:layout_width="0dp"
                    android:layout_height="84dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_quick_action_dark"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_logout"
                        android:tint="#FF6B6B"
                        android:layout_marginBottom="6dp"
                        android:contentDescription="Logout" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logout"
                        android:textSize="11sp"
                        android:textColor="#FF6B6B"
                        android:gravity="center"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══ RECENT ACTIVITY ══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Activity"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_glass_card_dark"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:padding="14dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_store"
                    android:background="@drawable/bg_icon_blue"
                    android:padding="7dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Business" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvRecentBusiness1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="City Bank — Token #021"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvRecentTime1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yesterday, 2:30 PM"
                        android:textSize="11sp"
                        android:textColor="#5C7DB0" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvRecentStatus1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Done"
                    android:textSize="10sp"
                    android:textColor="#00E676"
                    android:background="@drawable/bg_status_badge_green"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_glass_card_dark"
                android:layout_marginHorizontal="16dp"
                android:padding="14dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_store"
                    android:background="@drawable/bg_icon_purple"
                    android:padding="7dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Business" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvRecentBusiness2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="City Hospital — Token #042"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvRecentTime2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today, 10:15 AM"
                        android:textSize="11sp"
                        android:textColor="#5C7DB0" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvRecentStatus2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active"
                    android:textSize="10sp"
                    android:textColor="#FFD54F"
                    android:background="@drawable/bg_status_badge_yellow"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>