<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060D1F">

    <!-- Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_mesh_gradient" />

    <!-- Glow Top-Right -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-70dp"
        android:layout_marginEnd="-70dp"
        android:background="@drawable/glow_circle_purple"
        android:alpha="0.4" />

    <!-- Glow Bottom-Left -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-60dp"
        android:layout_marginStart="-60dp"
        android:background="@drawable/glow_circle_blue"
        android:alpha="0.35" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="40dp">

            <!-- ══════════════════════════ -->
            <!--        LOGO SECTION       -->
            <!-- ══════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="36dp">

                <!-- Logo Icon Circle -->
                <ImageView
                    android:id="@+id/logoImg"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/queue"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="16dp"
                    android:contentDescription="App Logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QueueLess"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skip the line, save the time"
                    android:textSize="13sp"
                    android:textColor="#6B8CC7"
                    android:letterSpacing="0.02" />

            </LinearLayout>

            <!-- ══════════════════════════ -->
            <!--        LOGIN CARD         -->
            <!-- ══════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card_dark"
                android:padding="22dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login to continue"
                    android:textSize="12sp"
                    android:textColor="#5C7DB0"
                    android:layout_marginBottom="22dp" />

                <!-- Email Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email Address"
                    app:startIconDrawable="@drawable/ic_profile_placeholder"
                    app:startIconTint="#6B8CC7"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxBackgroundColor="#1A2444"
                    app:boxStrokeColor="#2952A3"
                    app:hintTextColor="#6B8CC7"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailEt"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:textColor="#FFFFFF"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Password"
                    app:startIconDrawable="@drawable/ic_token"
                    app:startIconTint="#6B8CC7"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#6B8CC7"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxBackgroundColor="#1A2444"
                    app:boxStrokeColor="#2952A3"
                    app:hintTextColor="#6B8CC7"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passwordEt"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:textColor="#FFFFFF"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ✅ NEW: Forgot Password -->
                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="Forgot Password?"
                    android:textSize="12sp"
                    android:textColor="#A8C4FF"
                    android:layout_marginBottom="22dp" />

                <!-- Login Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loginBtn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Login"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="14dp"
                    app:backgroundTint="#1565C0"
                    style="@style/Widget.Material3.Button"
                    android:layout_marginBottom="18dp" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="18dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#1E2D50" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  OR  "
                        android:textSize="11sp"
                        android:textColor="#3A4F7A" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#1E2D50" />

                </LinearLayout>

                <!-- Register Link -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account? "
                        android:textSize="13sp"
                        android:textColor="#5C7DB0" />

                    <TextView
                        android:id="@+id/registerTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Register"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#A8C4FF" />

                </LinearLayout>

            </LinearLayout>

            <!-- ✅ NEW: Role Info Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="2">

                <!-- User chip -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_glass_card_dark"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_profile_placeholder"
                        android:tint="#A8C4FF"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="User" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Login"
                        android:textSize="11sp"
                        android:textColor="#A8C4FF"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Admin chip -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_glass_card_dark"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_store"
                        android:tint="#7AFFD4"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="Admin" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Admin Login"
                        android:textSize="11sp"
                        android:textColor="#7AFFD4"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>