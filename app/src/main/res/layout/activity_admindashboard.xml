<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060D1F">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_mesh_gradient" />

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/glow_circle_purple"
        android:alpha="0.4" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="38dp"
                android:paddingBottom="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ADMIN PANEL"
                            android:textSize="10sp"
                            android:textColor="#6B8CC7"
                            android:letterSpacing="0.15"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="QueueLess"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>
                    </LinearLayout>

                    <!-- QR GENERATOR BUTTON -->
                    <ImageView
                        android:id="@+id/btnShowQr"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_qrcode"
                        android:background="@drawable/bg_icon_button"
                        android:padding="10dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Generate QR"/>

                    <ImageView
                        android:id="@+id/btnNotification"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_bell"
                        android:background="@drawable/bg_icon_button"
                        android:padding="10dp"
                        android:layout_marginEnd="8dp"/>

                    <ImageView
                        android:id="@+id/btnLogout"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_logout"
                        android:background="@drawable/bg_icon_button"
                        android:padding="10dp"
                        android:tint="#FF6B6B"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_selected_chip"
                    android:padding="12dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_store"
                        android:background="@drawable/bg_icon_teal"
                        android:padding="5dp"
                        android:layout_marginEnd="10dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Managing"
                            android:textSize="10sp"
                            android:textColor="#5C7DB0"/>
                        <TextView
                            android:id="@+id/tvBusinessName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Business"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● LIVE"
                        android:textSize="10sp"
                        android:textColor="#00E676"
                        android:background="@drawable/bg_live_badge"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- STATS CARDS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:weightSum="2">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_quick_action_blue">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOW SERVING"
                        android:textSize="9sp"
                        android:textColor="#A8C4FF"/>
                    <TextView
                        android:id="@+id/txtCurrentToken"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_quick_action_teal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY'S TOTAL"
                        android:textSize="9sp"
                        android:textColor="#7AFFD4"/>
                    <TextView
                        android:id="@+id/txtTotalTokens"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>
            </LinearLayout>

            <!-- REMAINING & WAIT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:weightSum="2">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    android:background="@drawable/bg_glass_card_dark"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_queue_status"
                        android:tint="#A8C4FF"/>
                    <TextView
                        android:id="@+id/txtRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:layout_marginStart="10dp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass_card_dark"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_history"
                        android:tint="#FFD54F"/>
                    <TextView
                        android:id="@+id/txtAvgWait"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- min"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:layout_marginStart="10dp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- QUEUE CONTROL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Queue Control"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card_blue"
                android:layout_marginHorizontal="16dp"
                android:padding="18dp">
                <ProgressBar
                    android:id="@+id/progressQueue"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progressDrawable="@drawable/progress_queue_gradient"
                    android:background="@drawable/bg_progress_track"
                    android:layout_marginBottom="18dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="▶  Next Token"
                    app:cornerRadius="14dp"
                    app:backgroundTint="#1565C0"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReset"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="↺  Reset Queue"
                    android:layout_marginTop="10dp"
                    android:textColor="#FF6B6B"
                    app:cornerRadius="14dp"
                    app:strokeColor="#FF6B6B"
                    app:strokeWidth="1dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
            </LinearLayout>

            <!-- SETTINGS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card_dark"
                android:layout_margin="16dp"
                android:padding="18dp">
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Avg Time (mins)"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtAvgTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="#FFFFFF"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdateTime"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Update Time"
                    android:layout_marginTop="10dp"
                    app:backgroundTint="#00695C"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>