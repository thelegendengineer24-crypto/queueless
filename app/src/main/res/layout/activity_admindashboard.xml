<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:background="@drawable/gradiente">

    <ImageView
        android:layout_width="188dp"
        android:layout_height="177dp"
        android:src="@drawable/queuelessadmin"/>

    <ImageView
        android:layout_width="395dp"
        android:layout_height="160dp"
        android:layout_marginStart="16dp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/queuelestextlogo" />

    <!-- CardView wrapping the LinearLayout -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_margin="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@android:color/transparent">

            <TextView
                android:layout_height="match_parent"
                android:layout_width="match_parent"
                android:id="@+id/txtCurrentToken"
                android:text="0"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#C31432"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_height="match_parent"
                android:layout_width="match_parent"
                android:id="@+id/txtTotalTokens"
                android:text="Total Tokens: 0"
                android:textSize="16sp"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/edtAvgTime"
                android:hint="Avg Time Per Token (mins)"
                android:inputType="number"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@android:color/white"
                android:padding="10dp"
                android:layout_marginBottom="15dp"/>

            <Button
                android:id="@+id/btnUpdateTime"
                android:text="Update Avg Time"
                android:background="@drawable/buttonbge"
                android:textColor="@android:color/white"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

            <Button
                android:id="@+id/btnNext"
                android:text="Next Token"
                android:background="@drawable/buttonbgc"
                android:textColor="@android:color/white"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"/>

            <Button
                android:id="@+id/btnReset"
                android:text="Reset Queue"
                android:background="@drawable/buttonbgd"
                android:textColor="@android:color/white"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"/>

            <Button
                android:id="@+id/btnBusinessRegister"
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/buttonbgb"
                android:text="Register Your Business"
                android:textColor="@android:color/white" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>