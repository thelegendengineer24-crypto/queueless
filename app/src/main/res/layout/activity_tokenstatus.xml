<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1E">

    <!-- Mesh Gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_mesh_gradient" />

    <!-- Glow Top -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="-100dp"
        android:layout_gravity="top|center_horizontal"
        android:background="@drawable/glow_circle_blue"
        android:alpha="0.25" />

    <!-- Glow Bottom-Right -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="-50dp"
        android:layout_marginEnd="-50dp"
        android:background="@drawable/glow_circle_purple"
        android:alpha="0.3" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- ══ HEADER ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="52dp"
                android:paddingBottom="24dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_icon_button"
                    android:padding="10dp"
                    android:contentDescription="Back"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Queueless"
                        android:textSize="12sp"
                        android:textColor="#6B8CC7"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Token Status"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Live Badge -->
                <TextView
                    android:id="@+id/tvLiveBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Live"
                    android:textSize="12sp"
                    android:textColor="#00E676"
                    android:background="@drawable/bg_live_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp" />
            </LinearLayout>

            <!-- ══ MAIN TOKEN CARD ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_glass_card_blue"
                    android:padding="28dp">

                    <!-- Business Name -->
                    <TextView
                        android:id="@+id/tvBusinessName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="City Hospital — OPD"
                        android:textSize="13sp"
                        android:textColor="#A8C4FF"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="6dp" />

                    <!-- Token Number -->
                    <TextView
                        android:id="@+id/tvYourToken"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#042"
                        android:textSize="88sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Token Number"
                        android:textSize="12sp"
                        android:textColor="#7A9AD4"
                        android:layout_marginBottom="20dp" />

                    <!-- Status Badge -->
                    <TextView
                        android:id="@+id/tvTokenStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Waiting"
                        android:textSize="13sp"
                        android:textColor="#FFD54F"
                        android:background="@drawable/bg_status_badge_yellow"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="7dp"
                        android:layout_marginBottom="28dp" />

                    <!-- Stats Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Now Serving"
                                android:textSize="11sp"
                                android:textColor="#7A9AD4"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/tvNowServing"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="#039"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="#00E676"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="48dp"
                            android:background="#1E3A6E" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ahead of You"
                                android:textSize="11sp"
                                android:textColor="#7A9AD4"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/tvAheadCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="48dp"
                            android:background="#1E3A6E" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Est. Wait"
                                android:textSize="11sp"
                                android:textColor="#7A9AD4"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/tvWaitTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="~15m"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#FFD54F"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Progress Bar -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Queue Progress"
                        android:textSize="11sp"
                        android:textColor="#7A9AD4"
                        android:layout_marginBottom="8dp"
                        android:layout_gravity="start" />

                    <ProgressBar
                        android:id="@+id/progressQueue"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:progress="60"
                        android:progressDrawable="@drawable/progress_queue_gradient"
                        android:background="@drawable/bg_progress_track"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvProgressStart"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="#001"
                            android:textSize="10sp"
                            android:textColor="#4A6499" />

                        <TextView
                            android:id="@+id/tvProgressEnd"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#042"
                            android:textSize="10sp"
                            android:textColor="#4A6499" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ CALL SOON ALERT (shown when your turn is near) ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_quick_action_blue"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_bell"
                        android:background="@drawable/bg_icon_button"
                        android:padding="8dp"
                        android:layout_marginEnd="14dp"
                        android:contentDescription="Alert" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Almost Your Turn!"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tvAlertMessage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Only 2 tokens ahead of you"
                            android:textSize="12sp"
                            android:textColor="#A8C4FF" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ QUICK ACTIONS ══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actions"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="16dp"
                android:weightSum="3">

                <!-- Refresh -->
                <LinearLayout
                    android:id="@+id/btnRefresh"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_quick_action_blue"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_refresh"
                        android:tint="#FFFFFF"
                        android:layout_marginBottom="7dp"
                        android:contentDescription="Refresh" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Refresh"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- History -->
                <LinearLayout
                    android:id="@+id/btnHistory"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_quick_action_teal"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_history"
                        android:tint="#FFFFFF"
                        android:layout_marginBottom="7dp"
                        android:contentDescription="History" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="History"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Cancel Token -->
                <LinearLayout
                    android:id="@+id/btnCancelToken"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_quick_action_dark"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_cancel"
                        android:tint="#FF6B6B"
                        android:layout_marginBottom="7dp"
                        android:contentDescription="Cancel" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cancel"
                        android:textSize="12sp"
                        android:textColor="#FF6B6B"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- ══ DONE STATE CARD (when token is served) ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_glass_card_dark"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="48sp"
                        android:textColor="#00E676"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your turn is done!"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Token has been served"
                        android:textSize="13sp"
                        android:textColor="#5C7DB0"
                        android:layout_marginBottom="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNewToken"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Take New Token"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#1565C0"
                        style="@style/Widget.Material3.Button" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>