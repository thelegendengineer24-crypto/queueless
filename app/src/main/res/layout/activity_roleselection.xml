<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mesh_gradient">

    <!-- Top-right purple glow -->
    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-140dp"
        android:layout_marginEnd="-110dp"
        android:background="@drawable/glow_circle_purple"
        android:alpha="0.55" />

    <!-- Bottom-left blue glow -->
    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="-110dp"
        android:layout_marginStart="-60dp"
        android:background="@drawable/glow_circle_blue"
        android:alpha="0.45" />

    <!-- Center Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true"
        android:paddingHorizontal="28dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/appLogo"
            android:layout_width="190dp"
            android:layout_height="110dp"
            android:layout_marginBottom="36dp"
            android:src="@drawable/queuelestextlogo"
            android:scaleType="fitCenter"
            android:elevation="10dp"
            android:contentDescription="Queueless Logo" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Your Path"
            android:textColor="#E2E8F0"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="10dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select how you want to use QueueLess"
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="48dp" />

        <!-- ── USER CARD BUTTON ── -->
        <LinearLayout
            android:id="@+id/cardUser"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_quick_action_blue"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:elevation="6dp">

            <LinearLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_icon_blue"
                android:gravity="center">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/baseline_person_24"
                    android:scaleType="fitCenter"
                    android:contentDescription="User" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue as User"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Book tokens &amp; track queues"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/baseline_generating_tokens_24"
                android:alpha="0.7"
                android:scaleType="fitCenter"
                android:contentDescription="Arrow" />

        </LinearLayout>

        <!-- ── ADMIN CARD BUTTON ── -->
        <LinearLayout
            android:id="@+id/cardAdmin"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_quick_action_teal"
            android:paddingHorizontal="20dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:elevation="6dp">

            <LinearLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_icon_teal"
                android:gravity="center">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/baseline_person_24"
                    android:scaleType="fitCenter"
                    android:contentDescription="Admin" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue as Admin"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage business &amp; services"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/baseline_generating_tokens_24"
                android:alpha="0.7"
                android:scaleType="fitCenter"
                android:contentDescription="Arrow" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>